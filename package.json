{
  "name": "donjon-crawler-claudo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "2D dungeon crawler (twin-stick roguelite) — deterministic logic core + Phaser 3 rendering.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
